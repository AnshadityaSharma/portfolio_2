# the deployed site url (used for og image + metadata resolution)
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app

# optional: read-only websocket endpoint of the deployed exchange.
# when set, slot 01 connects live (with backoff + gap detection) and
# falls back to the in-browser engine if the feed is down.
# leave unset to run the in-browser engine only.
# NEXT_PUBLIC_EXCHANGE_WS_URL=wss://your-exchange.up.railway.app/ws
# NEXT_PUBLIC_EXCHANGE_SYMBOL=SIM
